# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://shoposphere:shoposphere@localhost:5432/shoposphere
DATABASE_URL_TEST=postgresql://shoposphere:shoposphere@localhost:5432/shoposphere_test
DB_HOST=localhost
DB_PORT=5432
DB_USER=shoposphere
DB_PASSWORD=shoposphere
DB_NAME=shoposphere

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-prod
JWT_EXPIRY=3600
JWT_REFRESH_SECRET=your-refresh-secret-change-in-prod
JWT_REFRESH_EXPIRY=604800

# ── AWS Cognito (use mock for local dev) ──────────────────
COGNITO_USER_POOL_ID=ap-south-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_REGION=ap-south-1
USE_LOCAL_AUTH=true

# ── AWS ───────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=shoposphere-assets-dev

# ── Razorpay ──────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ── SMTP / Notifications ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@shoposphere.in
SMTP_PASS=your-smtp-password
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_FROM=+91XXXXXXXXXX

# ── WhatsApp Cloud API ────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=your-whatsapp-cloud-api-token
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_API_VERSION=v22.0
WHATSAPP_TEMPLATE_LANGUAGE=en_US
WHATSAPP_DEFAULT_TEMPLATE_NAME=hello_world
WHATSAPP_BROADCAST_TEMPLATE_NAME=hello_world
WHATSAPP_BROADCAST_TEMPLATE_LANGUAGE=en_US
WHATSAPP_BROADCAST_TEMPLATE_BODY_PARAM_COUNT=0
WHATSAPP_INVOICE_TEMPLATE_NAME=hello_world
WHATSAPP_INVOICE_TEMPLATE_LANGUAGE=en_US
WHATSAPP_INVOICE_TEMPLATE_BODY_PARAM_COUNT=0

# ── App ───────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3003
PORT=3003
LOG_LEVEL=debug
